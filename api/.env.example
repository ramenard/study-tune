# Application
NODE_ENV=development
PORT=3001
# Comma-separated list of allowed origins for CORS (defaults to http://localhost:4200)
CORS_ORIGIN=http://localhost:4200
# Public URL of this API, used to build the kie.ai webhook callback URL
APP_PUBLIC_URL=https://your-public-url.example.com

# Auth
JWT_SECRET=change-me

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=musicdb

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=music
MINIO_PUBLIC_URL=http://localhost:9000

# External APIs
KIE_API_KEY=your-kie-api-key
MISTRAL_API_KEY=your-mistral-api-key
GEMINI_API_KEY=your-gemini-api-key
HUGGING_TOKEN=your-hugging-face-token
